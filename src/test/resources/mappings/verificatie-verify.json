{
  "priority": 1,
  "request": {
    "method": "POST",
    "url": "/verify",
    "bodyPatterns": [
      {
        "matchesJsonPath": {
          "expression": "$.code",
          "equalTo": "000000"
        }
      }
    ]
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "success": true
    }
  }
}
